{
  "manifest_version": 3,
  "name": "You Mean LLMs",
  "version": "1.0",
  "description": "Replaces 'AI' and 'Artificial Intelligence' with more accurate terminology",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
